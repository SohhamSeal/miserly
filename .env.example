# =============================================================================
# miserly — feature flags (build-time)
# =============================================================================
# Copy this file to `.env` (or just run `npm run setup`) to customize which
# features are on. Flags take effect when you (re)start the dev server or
# rebuild — they are baked in at build time by Vite.
#
# IMPORTANT: turning a HEAVY feature ON here is not enough on its own — its npm
# package(s) must also be installed. The easiest way to do both is:
#
#     npm run setup
#
# Accepted truthy values: true / 1 / yes / on   (anything else is treated as off)
# -----------------------------------------------------------------------------

# --- Heavy, install-optional features (OFF by default to keep installs lean) ---

# Exact OpenAI token counts via gpt-tokenizer (~55 MB).
# When off, miserly uses a fast ~4-characters-per-token estimate.
VITE_FEATURE_ACCURATE_TOKENIZER=false

# Parse uploaded PDF / DOCX files via pdfjs-dist + mammoth (~20 MB).
VITE_FEATURE_DOCUMENT_PARSING=false

# --- Core UX features (always installed, ON by default, toggle freely) ---

VITE_FEATURE_ANIMATIONS=true
VITE_FEATURE_RICH_EDITOR=true
VITE_FEATURE_COST_COMPARISON=true
VITE_FEATURE_CONTEXT_BUDGET=true
VITE_FEATURE_SAMPLE_DOCUMENTS=true
